# Copy to .env in this directory and fill in values.
#   cp .env.sample .env
# Compose loads .env for ${VAR} substitutions in docker-compose.yml.

# --- Required in production (private server + proxy auth) ---
# Same value as CONFIG.sharedSecret in src/pkjs/index.js
SHARED_SECRET=

# --- Tesla Fleet region (must match your Tesla app / partner token audience) ---
# North America:
FLEET_API_BASE=https://fleet-api.prd.na.vn.cloud.tesla.com
# Europe (uncomment if your fleet region is EU):
# FLEET_API_BASE=https://fleet-api.prd.eu.vn.cloud.tesla.com

# --- Host port mapping (container: 8080 = public server, 9000 = private server) ---
PUBLIC_PORT=8080
PRIVATE_PORT=9000

# --- Bind address inside container for private server (optional override) ---
# PRIVATE_LISTEN=:9000

# --- OAuth + public key (must match Tesla Developer portal + PKJS CONFIG) ---
PUBLIC_CALLBACK_PATH=/oauth/redirect
PUBLIC_KEY_PATH=/.well-known/appspecific/com.tesla.3p.public-key.pem

# Paths inside the container (default volume: ./tesla-fleet-keys -> /tesla-fleet-keys)
PUBLIC_KEY_FILE=/tesla-fleet-keys/com.tesla.3p.public-key.pem
TOKEN_FILE=/tesla-fleet-keys/tokens.json

# --- Optional overrides ---
# PROXY_PREFIX=/proxy

# --- register-partner.mjs (run on host: npm run register-partner; not used by Compose) ---
# TESLA_CLIENT_ID=
# TESLA_CLIENT_SECRET=
# PARTNER_DOMAIN=pebblecar.example.com
# FLEET_AUTH_URL=https://fleet-auth.prd.vn.cloud.tesla.com/oauth2/v3/token
# TESLA_PARTNER_SCOPE=openid vehicle_device_data vehicle_cmds vehicle_charging_cmds
